generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  email     String   @unique
  username  String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations   ConversationMember[]
  messages        Message[]
  invites         Invite[]
  workspaces      WorkspaceMember[]
  ownedWorkspaces Workspace[]          @relation("WorkspaceOwner")
}

enum ConversationType {
  DM
  CHANNEL
}

model Conversation {
  id          String           @id
  type        ConversationType @default(DM)
  isPrivate   Boolean          @default(true)
  name        String?
  workspaceId String?
  dmPair      String?          @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  members   ConversationMember[]
  messages  Message[]
  workspace Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  latestMessageId String?
  latestMessage   Message? @relation("ConversationLatestMessage", fields: [latestMessageId], references: [id])
}

model ConversationMember {
  conversationId    String
  userId            String
  lastReadMessageId String?
  joinedAt          DateTime @default(now())

  // Relations
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage Message?     @relation("ConversationMemberLastRead", fields: [lastReadMessageId], references: [id])

  @@id([conversationId, userId])
  @@index([userId, conversationId])
}

model Message {
  id             String               @id
  content        String
  conversationId String
  userId         String
  isEdited       Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  // Relations
  conversation   Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  readByMembers  ConversationMember[] @relation("ConversationMemberLastRead")
  latestIn       Conversation[]       @relation("ConversationLatestMessage")

  @@index([conversationId, id])
}

enum InviteType {
  USER
  CONVERSATION
  WORKSPACE
  CHANNEL
}

model Invite {
  id         String     @id @default(cuid())
  token      String     @unique
  type       InviteType
  entityId   String
  createdBy  String
  expiresAt  DateTime?
  maxUses    Int?
  usedCount  Int        @default(0)
  lastUsedAt DateTime?
  revoked    Boolean    @default(false)
  createdAt  DateTime   @default(now())

  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([type, entityId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model Workspace {
  id        String   @id
  name      String
  slug      String   @unique
  imageUrl  String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  WorkspaceMember[]
  channels Conversation[]
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
}
